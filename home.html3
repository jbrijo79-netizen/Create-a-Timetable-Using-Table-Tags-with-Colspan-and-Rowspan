<!DOCTYPE html>
<html>
<head>
    <title>College Timetable</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f2f2f2;
        }

        h2 {
            text-align: center;
            color: darkblue;
        }

        table {
            width: 80%;
            margin: auto;
            border-collapse: collapse;
            background-color: white;
        }

        table, th, td {
            border: 2px solid black;
        }

        th, td {
            padding: 10px;
            text-align: center;
        }

        th {
            background-color: #4CAF50;
            color: white;
        }

        .break {
            background-color: #ffeb99;
            font-weight: bold;
        }
    </style>
</head>
<body>

<h2>College Timetable</h2>

<table>
    <tr>
        <th>Day</th>
        <th>9:00-10:00</th>
        <th>10:00-11:00</th>
        <th>11:00-11:30</th>
        <th>11:30-12:30</th>
        <th>12:30-1:30</th>
    </tr>

    <tr>
        <td>Monday</td>
        <td>Math</td>
        <td>English</td>
        <td rowspan="5" class="break">BREAK</td>
        <td>Java</td>
        <td>Physics</td>
    </tr>

    <tr>
        <td>Tuesday</td>
        <td colspan="2">Web Technology Lab</td>
        <td>DBMS</td>
        <td>Chemistry</td>
    </tr>

    <tr>
        <td>Wednesday</td>
        <td>Java</td>
        <td>Math</td>
        <td colspan="2">Computer Networks Lab</td>
    </tr>

    <tr>
        <td>Thursday</td>
        <td>English</td>
        <td>Physics</td>
        <td>Web Technology</td>
        <td>Math</td>
    </tr>

    <tr>
        <td>Friday</td>
        <td colspan="2">Project Work</td>
        <td>Seminar</td>
        <td>Sports</td>
    </tr>

</table>

</body>
</html>